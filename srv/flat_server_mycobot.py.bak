import argparse
import json
import socket
import threading
import time

# ----------------------------------------------------------------------
# Configuration - Cartesian Space (Grid Control)
# ----------------------------------------------------------------------
HOST = "0.0.0.0"
PORT = 6000

SERIAL_PORT = "/dev/ttyAMA0"
BAUD_RATE = 1000000

JOG_STEP_MM = 15           
MOVE_SPEED = 25            
MIN_SECONDS_BETWEEN_MOVES = 0.25

GRIPPER_OPEN_VALUE = 100
GRIPPER_CLOSED_VALUE = 0
GRIPPER_SPEED = 25

# --- HEIGHT & ORIENTATION SETTINGS ---
HOVER_Z = 200              
TABLE_Z = 80               

# [Rx, Ry, Rz] in degrees. -180, 0, 0 is the mathematical default for "straight down".
# TWEAK THIS: If Joint 4 tilts inward, try changing the middle number (Ry) to -10, -20, or +10.
# If it tilts side-to-side, tweak the first number (Rx) slightly away from -180.
CLAW_ORIENTATION = [-180, 0, 135]

# Reduced X_MAX slightly. If it's struggling to stay flat far away, 
# it means it's overextending. Keeping it inside a comfortable box helps the IK solver.
X_MIN, X_MAX = 100, 250    
Y_MIN, Y_MAX = -150, 150   

MIN_SECONDS_BETWEEN_PEACE = 1.0
MIN_SECONDS_BETWEEN_HOME = 1.0

DIRECTION_AXIS = {
    "up": (0, 1),       
    "down": (0, -1),    
    "left": (1, 1),     
    "right": (1, -1),   
}

class ArmController:
    def __init__(self, simulate: bool):
        self.simulate = simulate
        self._last_move_time = 0.0
        self._last_home_time = 0.0
        self._last_peace_time = 0.0
        self._lock = threading.Lock()
        
        self.sim_coords = [180, 0, HOVER_Z] + CLAW_ORIENTATION 

        if simulate:
            print("[server] SIMULATE mode: Cartesian testing.")
            self.mc = None
        else:
            from pymycobot.mycobot import MyCobot
            print(f"[server] Connecting to arm on {SERIAL_PORT} @ {BAUD_RATE}...")
            self.mc = MyCobot(SERIAL_PORT, BAUD_RATE)
            time.sleep(1)
            
            print("[server] Moving to safe start position...")
            # Enforce the strict orientation right from the start
            self.mc.send_coords([180, 0, HOVER_Z] + CLAW_ORIENTATION, 30, 1)
            time.sleep(3)
            print("[server] Connected and ready.")

# --- HARD RESET STANDBY METHOD ---
    def set_standby(self, active: bool):
        with self._lock:
            self.is_standby = active
            
        if active:
            print("[arm] STANDBY MODE -> Forcing high angle position...")
            if not self.simulate:
                # 1. Kill any active/stuck coordinate movements
                self.mc.stop()
                time.sleep(0.1)
                
                # 2. Force the firmware to update and clear its kinematic queue
                _ = self.mc.get_angles()
                time.sleep(0.1)
                
                # 3. Send raw joint angles directly (0,0,0,0,0,135)
                # We use a slightly safer speed (35) to prevent overshoot errors
                self.mc.send_angles([0, 0, 0, 0, 0, 135], 25)
                print("[arm] Standby angles dispatched.")
        else:
            print("[arm] RESUME MODE -> Forcing grid coordinate plane...")
            if not self.simulate:
                # 1. Clear angle tracking
                self.mc.stop()
                time.sleep(0.1)
                
                # 2. Force read coords to shake the firmware back into Cartesian mode
                _ = self.mc.get_coords()
                time.sleep(0.1)
                
                # 3. Send back to the plane
                target = [180, 0, HOVER_Z] + CLAW_ORIENTATION
                self.mc.send_coords(target, 35, 1)
                print("[arm] Grid coordinates dispatched.")
                
        self._last_move_time = time.time()

    def _cooldown_ok(self) -> bool:
        return (time.time() - self._last_move_time) >= MIN_SECONDS_BETWEEN_MOVES

    def gripper_open(self):
        with self._lock:
            if not self.simulate:
                self.mc.set_gripper_value(GRIPPER_OPEN_VALUE, GRIPPER_SPEED)

    def gripper_close(self):
        with self._lock:
            if not self.simulate:
                self.mc.set_gripper_value(GRIPPER_CLOSED_VALUE, GRIPPER_SPEED)

    def jog(self, direction: str):
        with self._lock:
            if not self._cooldown_ok():
                return
            
            axis_info = DIRECTION_AXIS.get(direction)
            if not axis_info:
                return
                
            axis_idx, sign = axis_info
            
            if not self.simulate:
                coords = self.mc.get_coords()
                if not coords or len(coords) < 6:
                    return
                
                target_coords = list(coords)
                
                # 1. Update Position
                target_coords[axis_idx] += sign * JOG_STEP_MM
                target_coords[0] = max(X_MIN, min(X_MAX, target_coords[0]))
                target_coords[1] = max(Y_MIN, min(Y_MAX, target_coords[1]))
                
                # 2. STRICTLY ENFORCE HEIGHT (prevents distance sag)
                target_coords[2] = HOVER_Z 
                
                # 3. STRICTLY ENFORCE ORIENTATION (prevents Joint 4 tilt)
                target_coords[3] = CLAW_ORIENTATION[0]
                target_coords[4] = CLAW_ORIENTATION[1]
                target_coords[5] = CLAW_ORIENTATION[2]

                print(f"[arm] jog {direction} -> X:{target_coords[0]:.1f}, Y:{target_coords[1]:.1f}")
                self.mc.send_coords(target_coords, MOVE_SPEED, 1)
            else:
                self.sim_coords[axis_idx] += sign * JOG_STEP_MM
                self.sim_coords[0] = max(X_MIN, min(X_MAX, self.sim_coords[0]))
                self.sim_coords[1] = max(Y_MIN, min(Y_MAX, self.sim_coords[1]))
                print(f"[sim] jog {direction} -> coords: {self.sim_coords[:3]}")
                
            self._last_move_time = time.time()

    def go_straight_down(self):
        with self._lock:
            if (time.time() - self._last_peace_time) < MIN_SECONDS_BETWEEN_PEACE:
                return
            
            print(f"[arm] PEACE SIGN -> dropping Z to {TABLE_Z}mm")
            if not self.simulate:
                coords = self.mc.get_coords()
                if coords and len(coords) >= 6:
                    # Enforce X, Y, Z, Rx, Ry, Rz perfectly to prevent weird twisting on the way down
                    target = [coords[0], coords[1], TABLE_Z] + CLAW_ORIENTATION
                    self.mc.send_coords(target, MOVE_SPEED, 1)
            self._last_peace_time = time.time()

    def go_home(self):
        with self._lock:
            if (time.time() - self._last_home_time) < MIN_SECONDS_BETWEEN_HOME:
                return
                
            print(f"[arm] THUMBS UP -> raising Z to {HOVER_Z}mm")
            if not self.simulate:
                coords = self.mc.get_coords()
                if coords and len(coords) >= 6:
                    target = [coords[0], coords[1], HOVER_Z] + CLAW_ORIENTATION
                    self.mc.send_coords(target, MOVE_SPEED, 1)
            self._last_home_time = time.time()

    def stop(self):
        with self._lock:
            if not self.simulate:
                self.mc.stop()


def handle_client(conn: socket.socket, addr, arm: ArmController):
    buffer = b""
    with conn:
        conn.settimeout(5.0)
        while True:
            try:
                chunk = conn.recv(1024)
            except socket.timeout:
                continue
            except (ConnectionResetError, OSError):
                break
            if not chunk:
                break
            buffer += chunk
            while b"\n" in buffer:
                line, buffer = buffer.split(b"\n", 1)
                if not line.strip():
                    continue
                try:
                    msg = json.loads(line.decode("utf-8"))
                except json.JSONDecodeError:
                    continue
                dispatch(msg, arm)


def dispatch(msg: dict, arm: ArmController):
    gesture = msg.get("gesture")
    if gesture == "fist":
        arm.gripper_close()
    elif gesture == "open_palm":
        arm.gripper_open()
    elif gesture == "point":
        direction = msg.get("direction", "")
        arm.jog(direction)
    elif gesture == "home":
        arm.go_home()
    elif gesture == "peace":
        arm.go_straight_down()
    elif gesture == "stop":
        arm.stop()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--simulate", action="store_true")
    parser.add_argument("--port", type=int, default=PORT)
    args = parser.parse_args()

    arm = ArmController(simulate=args.simulate)

    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as srv:
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        srv.bind((HOST, args.port))
        srv.listen(1)
        print(f"[server] listening on {HOST}:{args.port}")
        try:
            while True:
                conn, addr = srv.accept()
                t = threading.Thread(target=handle_client, args=(conn, addr, arm), daemon=True)
                t.start()
        except KeyboardInterrupt:
            print("\n[server] shutting down")

if __name__ == "__main__":
    main()